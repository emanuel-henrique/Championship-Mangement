generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int            @id @default(autoincrement())
  name          String
  email         String         @unique
  password      String
  avatar        String?
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  championships Championship[]
  teams         Team[]
  players       Player[]

  @@map("users")
}

model Championship {
  id          Int                  @id @default(autoincrement())
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      Int                  @map("user_id")
  name        String
  description String?
  maxTeams    Int                  @map("max_teams")
  modality    Modality             @default(FUTEBOL)
  startDate   DateTime?            @map("start_date")
  endDate     DateTime?            @map("end_date")
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")
  teams       ChampionshipTeam[]
  matches     Match[]
  players     ChampionshipPlayer[]

  @@map("championships")
}

model ChampionshipTeam {
  id             Int          @id @default(autoincrement())
  championship   Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  championshipId Int          @map("championship_id")
  team           Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId         Int          @map("team_id")
  points         Int          @default(0)
  wins           Int          @default(0)
  draws          Int          @default(0)
  losses         Int          @default(0)
  goalsFor       Int          @default(0) @map("goals_for")
  goalsAgainst   Int          @default(0) @map("goals_against")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@unique([championshipId, teamId])
  @@map("championship_teams")
}

model Team {
  id Int @id @default(autoincrement())

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int  @map("user_id")

  name          String
  emblemUrl     String?            @map("emblem_url")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  players       Player[]
  championships ChampionshipTeam[]
  homeMatches   Match[]            @relation("HomeTeam")
  awayMatches   Match[]            @relation("AwayTeam")

  @@map("teams")
}

model Player {
  id            Int                  @id @default(autoincrement())
  team          Team?                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId        Int?                 @map("team_id")
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        Int                  @map("user_id")
  name          String
  birthDate     DateTime             @map("birth_date")
  jerseyNumber  Int                  @map("jersey_number")
  position      Position
  goals         Goal[]               @relation("GoalScorer")
  assists       Goal[]               @relation("GoalAssist")
  cards         Card[]
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")
  championships ChampionshipPlayer[]

  @@unique([teamId, jerseyNumber])
  @@map("players")
}

model ChampionshipPlayer {
  id             Int          @id @default(autoincrement())
  championship   Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  championshipId Int          @map("championship_id")
  player         Player       @relation(fields: [playerId], references: [id], onDelete: Cascade)
  playerId       Int          @map("player_id")
  goals          Int          @default(0)
  assists        Int          @default(0)
  yellowCards    Int          @default(0) @map("yellow_cards")
  redCards       Int          @default(0) @map("red_cards")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@unique([championshipId, playerId])
  @@map("championship_players")
}

model Match {
  id             Int          @id @default(autoincrement())
  championship   Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  championshipId Int          @map("championship_id")
  homeTeam       Team         @relation("HomeTeam", fields: [homeTeamId], references: [id])
  homeTeamId     Int          @map("home_team_id")
  awayTeam       Team         @relation("AwayTeam", fields: [awayTeamId], references: [id])
  awayTeamId     Int          @map("away_team_id")
  homeScore      Int          @default(0) @map("home_score")
  awayScore      Int          @default(0) @map("away_score")
  status         MatchStatus  @default(SCHEDULED)
  matchDate      DateTime     @default(now()) @map("match_date")
  finishedAt     DateTime?    @map("finished_at")
  goals          Goal[]
  cards          Card[]
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@map("matches")
}

model Goal {
  id             Int      @id @default(autoincrement())
  match          Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchId        Int      @map("match_id")
  player         Player   @relation("GoalScorer", fields: [playerId], references: [id], onDelete: Cascade)
  playerId       Int      @map("player_id")
  assistPlayer   Player?  @relation("GoalAssist", fields: [assistPlayerId], references: [id], onDelete: SetNull)
  assistPlayerId Int?     @map("assist_player_id")
  teamId         Int      @map("team_id")
  minute         Int?
  isOwnGoal      Boolean  @default(false) @map("is_own_goal")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("goals")
}

model Card {
  id        Int      @id @default(autoincrement())
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchId   Int      @map("match_id")
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  playerId  Int      @map("player_id")
  teamId    Int      @map("team_id")
  type      CardType
  minute    Int?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("cards")
}

enum CardType {
  YELLOW
  RED
}

enum Modality {
  FUTEBOL
  FUTSAL
}

enum MatchStatus {
  SCHEDULED
  IN_PROGRESS
  FINISHED
  CANCELED
}

enum Position {
  GOL
  ZAG
  LE
  LD
  VOL
  MEI
  MC
  MA
  MD
  ME
  ATA
  PD
  PE
  SA
  CA
  FIX
  ALA
  ALD
  ALE
  PIV
}
